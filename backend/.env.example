# ─────────────────────────────────────────────────────────────────────────────
# Genesis Global CMS — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# USAGE:
#   cp .env.example .env
#   Fill in all values. Run backend with: uvicorn app.main:app --reload
#
# SECURITY RULES:
#   - NEVER commit .env to version control (it is in .gitignore)
#   - NEVER share SERVICE_KEY or JWT_SECRET_KEY
#   - Rotate JWT_SECRET_KEY if you suspect compromise (all sessions invalidated)
#   - Use test/sandbox keys for development; switch to live keys for production
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────
# Valid values: development | staging | production
# "development" enables: /docs UI, verbose logging, hot-reload
# "production" disables: /docs UI, /redoc, /openapi.json
ENVIRONMENT=development


# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Where to find it:
#   Supabase Dashboard → Project Settings → Database → Connection string (URI)
#   Choose "Transaction" mode (port 6543) for PgBouncer pooling in production.
#   Choose "Session" mode (port 5432) for Alembic migrations.
#
# Format: postgresql+psycopg2://[user]:[password]@[host]:[port]/[database]
#
# Transaction mode (production / API queries):
DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?sslmode=require&pgbouncer=true
#
# Session mode (Alembic migrations — run locally only):
# DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require


# ── Supabase ──────────────────────────────────────────────────────────────────
# Where to find it:
#   Supabase Dashboard → Project Settings → API
#
# Your Supabase project URL (no trailing slash)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# service_role key — has full DB bypass RLS access. NEVER expose to clients.
# Starts with: eyJ...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_THIS

# anon/public key — safe for frontend JavaScript. Row Level Security still applies.
# Starts with: eyJ...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_THIS


# ── JWT (JSON Web Tokens) ─────────────────────────────────────────────────────
# Generate a secret with: python -c "import secrets; print(secrets.token_hex(32))"
# MINIMUM 32 characters. Recommended: 64+ characters.
# WARNING: Changing this key invalidates ALL active sessions.
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_NEVER_SHARE_NEVER_REUSE

# Algorithm — do not change unless you have a specific reason
JWT_ALGORITHM=HS256

# Access token lifetime in hours (24 = 1 day)
ACCESS_TOKEN_EXPIRE_HOURS=24

# Refresh token lifetime in days (30 = 1 month)
REFRESH_TOKEN_EXPIRE_DAYS=30


# ── Redis / Upstash ───────────────────────────────────────────────────────────
# Where to find it:
#   Upstash Console → Your Database → Details → Redis URL (TLS format)
#
# Format: rediss://:[password]@[endpoint].upstash.io:[port]
# Note: "rediss://" (with double-s) = TLS. Use "redis://" only for local dev.
#
# Production (Upstash TLS):
UPSTASH_REDIS_URL=rediss://:[YOUR-UPSTASH-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379
#
# Local development (no TLS):
# UPSTASH_REDIS_URL=redis://localhost:6379


# ── Flutterwave (Payment Gateway) ────────────────────────────────────────────
# Where to find it:
#   Flutterwave Dashboard → Settings → API Keys
#
# Use TEST keys for development, LIVE keys for production.
# Test secret key format:  FLWSECK_TEST-...
# Live secret key format:  FLWSECK-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-REPLACE_WITH_YOUR_KEY

# Encryption key for payload encryption (found alongside secret key)
FLUTTERWAVE_ENCRYPTION_KEY=REPLACE_WITH_YOUR_ENCRYPTION_KEY


# ── Termii (SMS Gateway) ──────────────────────────────────────────────────────
# Where to find it:
#   Termii Dashboard → Settings → API Key
#
# Cost: ~NGN 2 per SMS. Requires pre-funded account balance.
TERMII_API_KEY=TLbb_REPLACE_WITH_YOUR_TERMII_KEY

# Sender ID registered with Termii (business verification required, 24-48h approval)
# Must match exactly what was approved. "GenesisGlobal" = 13 chars (Termii limit: 11)
# If rejected, use a shorter variant like "Genesis" or "GGenChurch"
TERMII_SENDER_ID=GenesisGlobal


# ── SendGrid (Transactional Email) ───────────────────────────────────────────
# Where to find it:
#   SendGrid Dashboard → Settings → API Keys → Create API Key
#   Permission required: "Mail Send" (Restricted Access)
#
# Free tier: 100 emails/day
# Key format: SG.XXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_API_KEY=SG.REPLACE_WITH_YOUR_SENDGRID_KEY

# The verified sender email address (must be verified in SendGrid)
# Either a single address or a sender domain (e.g., @genesisglob.al)
FROM_EMAIL=noreply@genesisglob.al


# ── CORS (Cross-Origin Resource Sharing) ─────────────────────────────────────
# Comma-separated list of allowed frontend origins. No trailing slashes.
# Update after you deploy the frontend to Vercel.
#
# Example production:
# ALLOWED_ORIGINS=https://genesis-global-cms.vercel.app,https://cms.genesisglob.al
#
# Local development:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080


# ── Render Internal Routing (optional) ───────────────────────────────────────
# Used for internal service-to-service calls within Render's private network.
# Leave empty if services call each other via public URLs.
# Format: http://[service-name]:[port]  (no TLS on internal network)
RENDER_INTERNAL_URL=http://genesis-global-api:8000


# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum failed login attempts before lockout
RATE_LIMIT_AUTH_ATTEMPTS=5

# Lockout window in seconds (900 = 15 minutes)
RATE_LIMIT_AUTH_WINDOW_SECONDS=900
